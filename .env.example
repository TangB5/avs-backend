# ─────────────────────────────────────────────────────────────────────────────
# AVS BACKEND — Variables d'Environnement
# ─────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=4000
API_VERSION=v1
APP_NAME="AVS Backend API"

# Base de données
DATABASE_URL=""

# JWT — générer avec : openssl rand -base64 64
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_64
JWT_REFRESH_SECRET=GENERATE_WITH_openssl_rand_base64_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — URL du frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://avs-standard.com

# Redis (rate limiting / cache)
REDIS_URL=redis://localhost:6379

# Email
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_VOTRE_CLE
EMAIL_FROM=noreply@avs-standard.com

# Stockage
STORAGE_PROVIDER=local  # local | s3 | gcs
STORAGE_BUCKET=avs-assets

# Monitoring
SENTRY_DSN=https://VOTRE_DSN@sentry.io/0
LOG_LEVEL=debug
